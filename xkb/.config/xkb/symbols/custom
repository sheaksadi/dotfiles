// US layout with German umlauts on the AltGr (level-3) layer, placed on the
// letters they actually belong to -- AltGr+a is ä, not á.
//
// libxkbcommon searches $XDG_CONFIG_HOME/xkb before the system tree, so this
// needs no root and survives package updates.

default partial alphanumeric_keys modifier_keys
xkb_symbols "umlaut" {
    include "us(basic)"
    name[Group1] = "English (US, umlauts on AltGr)";

    key <AC01> { [ a, A, adiaeresis, Adiaeresis ] };  // a -> ä / Ä
    key <AD03> { [ e, E, ediaeresis, Ediaeresis ] };  // e -> ë / Ë
    key <AD09> { [ o, O, odiaeresis, Odiaeresis ] };  // o -> ö / Ö
    key <AD07> { [ u, U, udiaeresis, Udiaeresis ] };  // u -> ü / Ü
    key <AC02> { [ s, S,     ssharp,      U1E9E ] };  // s -> ß / ẞ

    include "level3(ralt_switch)"
};
